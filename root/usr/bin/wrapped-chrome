#!/bin/bash

BIN=/usr/bin/brave-browser
USER_DATA_DIR="/config/.config/BraveSoftware/Brave-Browser"

# Cleanup stale locks if brave is not running
if ! pgrep brave > /dev/null; then
  rm -f ${USER_DATA_DIR}/Singleton*
fi

${BIN} \
  --no-first-run \
  --no-sandbox \
  --password-store=basic \
  --start-maximized \
  --user-data-dir="${USER_DATA_DIR}" \
  --renderer-process-limit=2 \
  --disable-gpu \
  --disable-software-rasterizer \
  --js-flags="--max-old-space-size=512" \
  --enable-low-end-device-mode \
  --disable-extensions \
  --disable-background-networking \
  --disable-sync \
  --disable-default-apps \
  --no-default-browser-check \
  --disable-features=Translate,BraveWallet,BraveRewards,BraveNews \
  --homepage "about:blank" \
  --disable-site-isolation-trials \
   "$@" > /dev/null 2>&1
