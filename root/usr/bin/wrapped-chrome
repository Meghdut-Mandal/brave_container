#!/bin/bash

BIN=/usr/bin/brave-browser
USER_DATA_DIR="/config/.config/BraveSoftware/Brave-Browser"

# Cleanup stale locks if brave is not running
if ! pgrep brave > /dev/null; then
  rm -f ${USER_DATA_DIR}/Singleton*
fi

${BIN} \
  --no-first-run \
  --no-sandbox \
  --password-store=basic \
  --start-maximized \
  --user-data-dir="${USER_DATA_DIR}" \
   "$@" > /dev/null 2>&1
